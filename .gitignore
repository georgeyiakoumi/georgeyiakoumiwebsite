# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Lighthouse audit reports (regenerate locally, don't commit)
/accessibility-reports

# Performance reports - ignore JSON data, keep docs and tools
/performance-reports/*.json
!/performance-reports/PERFORMANCE_AUDIT.md
!/performance-reports/compare.js

*storybook.log
storybook-static

# CMS (Strapi) specific
/cms/.strapi
/cms/dist
/cms/build
/cms/.strapi-updater.json
/cms/.strapi-cloud.json
/cms/.tmp
/cms/database/
/cms/public/uploads/*
!/cms/public/uploads/.gitkeep

# Local Netlify folder
.netlify

# References folder
.references

# Claude Code setup guides (local development documentation)
claude-guides/

# Agent skills (installed locally via npx skills)
.agents/
.claude/skills/
skills-lock.json
