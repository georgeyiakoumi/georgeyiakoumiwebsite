{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": false
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "project_thumb": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "hero_caption": {
      "type": "string"
    },
    "date": {
      "type": "date"
    },
    "end_date": {
      "type": "date"
    },
    "tools": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tool.tool"
    },
    "project_client": {
      "type": "string"
    },
    "project_role": {
      "type": "string"
    },
    "snapshot_items": {
      "type": "component",
      "component": "project-blocks.snapshot-item",
      "repeatable": true
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "project-blocks.video",
        "project-blocks.stats",
        "project-blocks.rich-text",
        "project-blocks.image",
        "project-blocks.comparison-slider",
        "project-blocks.carousel",
        "project-blocks.code-block"
      ]
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "client",
        "personal",
        "article"
      ]
    },
    "website_url": {
      "type": "string"
    },
    "github_url": {
      "type": "string"
    }
  }
}
